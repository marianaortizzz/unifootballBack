# --- Backend UniFootball ---
# Postgres (Supabase): Connection string con SSL
DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.xxxx.supabase.co:5432/postgres

# MongoDB Atlas: eventos en vivo / notificaciones
MONGODB_URI=mongodb+srv://usuario:TU_PASSWORD@cluster.xxxx.mongodb.net/?appName=unifootball

# Secreto para firmar los JWT (usa una cadena larga y aleatoria)
JWT_SECRET=cambia-esto-por-un-secreto-largo

# Puerto donde escucha la API
PORT=3000

# Origen permitido por CORS (el dominio del frontend en producción)
# En desarrollo: http://localhost:5173
CORS_ORIGIN=http://localhost:5173
